# Backend code-explorer-mcp HTTP transport
# Démarrer côté code-explorer : `code-explorer serve` (port 3000 par défaut)
# ou `code-explorer serve --port 8080` puis ajuste l'URL ici.
VITE_MCP_URL=http://localhost:3000

# Optionnel — token d'auth si CODE_EXPLORER_HTTP_TOKEN est défini côté serveur
# VITE_MCP_TOKEN=your-token-here
